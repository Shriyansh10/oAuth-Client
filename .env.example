# =========================

# 🌍 APP CONFIG

# =========================

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# =========================

# 🔐 AUTH (OAuth / OIDC)

# =========================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Session / JWT

SESSION_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=1d

# =========================

# 🗄️ DATABASE

# =========================

DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# Optional (if splitting config)

DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# =========================

# 🧠 CACHE (Redis)

# =========================

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================

# 📧 EMAIL (SMTP)

# =========================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=[no-reply@example.com](mailto:no-reply@example.com)

# =========================

# ☁️ STORAGE (S3 / Cloud)

# =========================

S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# =========================

# 🔒 SECURITY

# =========================

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# =========================

# 📊 LOGGING & MONITORING

# =========================

LOG_LEVEL=info
SENTRY_DSN=

# =========================

# 🔁 FEATURE FLAGS (optional)

# =========================

ENABLE_SIGNUP=true
ENABLE_ANALYTICS=false

# =========================

# 🧪 DEV / DEBUG

# =========================

DEBUG=false
